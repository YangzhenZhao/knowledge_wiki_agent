# 环境配置文件

# ==================== 模型提供者配置 ====================
# LLM 提供者，可选值: "ollama" 或 "openai"
LLM_PROVIDER=ollama

# Embedding 提供者，可选值: "ollama" 或 "openai"
# 使用 GLM 时设置为 openai，并配置 OPENAI_BASE_URL 指向 GLM API
EMBED_PROVIDER=ollama

# ==================== Ollama 配置 ====================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# Embedding 模型（推荐 nomic-embed-text 或 mxbai-embed-large）
OLLAMA_EMBED_MODEL=nomic-embed-text

# ==================== OpenAI API 配置 ====================
# 当 LLM_PROVIDER=openai 或 EMBED_PROVIDER=openai 时使用
OPENAI_API_KEY=sk-xxx
# 可修改为其他兼容 OpenAI API 的服务地址
# 例如 GLM: https://open.bigmodel.cn/api/paas/v4
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Embedding 模型（使用 GLM 时设置为 embedding-3）
OPENAI_EMBED_MODEL=text-embedding-3-small

# ==================== ChromaDB 配置 ====================
# ChromaDB 数据存储目录
CHROMA_PERSIST_DIR=./chroma_db

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8000

# Admin 认证密钥（用于上传文档、问答等管理操作）
# 请修改为安全的密钥，访问管理功能时需要带上此 token
# 例如: http://localhost:8000?token=your-secure-admin-key
ADMIN_API_KEY=your-secure-admin-key

# 应用配置
# 网页标题
APP_TITLE=知识库问答 Agent